<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Hourly: check all org-unit quota thresholds -->
        <record id="cron_check_quotas" model="ir.cron">
            <field name="name">OpenAI Billing: Check Quota Thresholds</field>
            <field name="model_id" ref="model_openai_billing_org_unit"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_quotas()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Monthly: reset alert flags + reactivate hard-limited depts -->
        <record id="cron_reset_monthly" model="ir.cron">
            <field name="name">OpenAI Billing: Monthly Alert Reset</field>
            <field name="model_id" ref="model_openai_billing_org_unit"/>
            <field name="state">code</field>
            <field name="code">model._cron_reset_monthly_alerts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
